# MongoDB connection string
# Local:  mongodb://localhost:27017/panda-miner
# Atlas:  mongodb+srv://<user>:<password>@<cluster>.mongodb.net/panda-miner
MONGO_URI=
MONGO_DNS_SERVERS=8.8.8.8,8.8.4.4
MONGO_FORCE_STANDARD_URI=false
MONGO_RECONNECT_MS=10000

# TLS/SSL options (only set to true for testing - NOT for production)
# If you get SSL alert 80 errors, try setting this to true temporarily
MONGO_TLS_ALLOW_INVALID_CERTS=true

# Your Telegram bot token from @BotFather (needed to verify initData)
BOT_TOKEN=

# Server port
PORT=3000

# Set to "production" when deploying for real
NODE_ENV=development

# ONLY for local testing outside Telegram (no real initData available).
# Leave this unset/false in production — it disables auth verification.
ALLOW_DEV_AUTH=true
